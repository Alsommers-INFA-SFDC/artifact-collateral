        let currentChart = null;

        function syntaxHighlight(json) {
            if (typeof json != 'string') {
                json = JSON.stringify(json, undefined, 2);
            }
            json = json.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
            return json.replace(/("(\\u[a-zA-Z0-9]{4}|\\[^u]|[^\\"])*"(\s*:)?|\b(true|false|null)\b|-?\d+(?:\.\d*)?(?:[eE][+\-]?\d+)?)/g, function (match) {
                let cls = 'text-amber-400'; 
                if (/^"/.test(match)) {
                    if (/:$/.test(match)) {
                        cls = 'text-sky-300 font-semibold'; 
                    } else {
                        cls = 'text-emerald-400'; 
                    }
                } else if (/true|false/.test(match)) {
                    cls = 'text-pink-400'; 
                } else if (/null/.test(match)) {
                    cls = 'text-slate-500'; 
                }
                return '<span class="' + cls + '">' + match + '</span>';
            });
        }

        function loadDocumentView(type) {
            document.querySelectorAll('.nav-button').forEach(btn => {
                btn.classList.remove('active', 'bg-sky-500', 'text-white');
                btn.classList.add('bg-white', 'text-slate-700');
            });
            const activeBtn = document.getElementById(`btn-${type}`);
            activeBtn.classList.remove('bg-white', 'text-slate-700');
            activeBtn.classList.add('active', 'bg-sky-500', 'text-white');

            const config = viewConfig[type];
            document.getElementById('doc-title').innerHTML = `<span class="bg-amber-100 text-amber-800 px-2 py-1 rounded text-sm uppercase tracking-wide">Document</span> ${config.title}`;
            document.getElementById('doc-desc').textContent = config.desc;

            const jsonDisplay = document.getElementById('json-display');
            jsonDisplay.innerHTML = syntaxHighlight(mdmData[type]);

            if (currentChart) {
                currentChart.destroy();
            }
            currentChart = config.renderViz();
        }

        function showSyndicationDetails(system) {
            ['pos', 'olo', 'print'].forEach(sys => {
                document.getElementById(`syn-desc-${sys}`).classList.add('hidden');
            });
            const descEl = document.getElementById(`syn-desc-${system}`);
            if(descEl.classList.contains('hidden')) {
                descEl.classList.remove('hidden');
            }
        }

        document.addEventListener('DOMContentLoaded', () => {
